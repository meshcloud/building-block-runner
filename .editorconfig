# This file is for unifying the coding style for different editors and IDEs
# See editorconfig.org

root = true

[*.{kt,kts}]
indent_size = 2
# The following options are supported by IntelliJ only:
ij_continuation_indent_size = 2
ij_kotlin_continuation_indent_size = 2
ij_kotlin_name_count_to_use_star_import = 5
ij_kotlin_name_count_to_use_star_import_for_members = 3

ktlint_standard_if-else-bracing = enabled
ktlint_standard_if-else-wrapping = enabled

# Disabled ktlint rules: To ease the migration to ktlint, we're disabling a whole bunch of rules.
#  This does not mean we don't consider these rules useful.
ktlint_standard_no-blank-line-before-rbrace = disabled
ktlint_standard_no-wildcard-imports = disabled
ktlint_standard_max-line-length = disabled
ktlint_standard_filename = disabled
ktlint_standard_class-naming = disabled
ktlint_standard_property-naming = disabled
ktlint_standard_enum-entry-naming = disabled
ktlint_standard_enum-entry-name-case = disabled
ktlint_standard_function-naming = disabled
ktlint_standard_comment-spacing = disabled
ktlint_standard_no-consecutive-comments = disabled
ktlint_standard_string-template-indent = disabled
ktlint_standard_multiline-expression-wrapping = disabled
ktlint_standard_trailing-comma-on-call-site = disabled
ktlint_standard_function-signature = disabled
ktlint_standard_no-empty-first-line-in-class-body = disabled
ktlint_standard_trailing-comma-on-declaration-site = disabled
ktlint_standard_function-expression-body = disabled
ktlint_standard_no-consecutive-blank-lines = disabled
ktlint_standard_no-empty-file = disabled
ktlint_standard_chain-method-continuation = disabled
ktlint_standard_wrapping = disabled
ktlint_standard_class-signature = disabled
ktlint_standard_argument-list-wrapping = disabled
ktlint_standard_parameter-list-wrapping = disabled
ktlint_standard_no-multi-spaces = disabled
ktlint_standard_value-parameter-comment = disabled
ktlint_standard_kdoc = disabled
ktlint_standard_mixed-condition-operators = disabled

insert_final_newline = true
end_of_line = lf

[*.gradle]
indent_size = 2
insert_final_newline = true
end_of_line = lf

# config for Apache Velocity markdown files:
[*.vm]
indent_style = space
indent_size = 4
insert_final_newline = true
end_of_line = lf

[*.sql]
indent_size = 2
# Format SQL keywords in upper case. Also an IntelliJ-only setting.
ij_sql_keyword_case = 2
insert_final_newline = true
end_of_line = lf
