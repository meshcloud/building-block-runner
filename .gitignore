out/
.DS_Store
.settings
.project
.classpath
bin/


# IDE
.idea/

# Terraform directories
.terraform

# Terraform state files (only relevant if not using remote backend exclusively)
*.tfstate
*.tfstate.*

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json
# ...but golden test fixtures under testdata/ are tracked on purpose (tests depend on them);
# without this a history rewrite that untracks then `git add -A`s would silently drop them.
!**/testdata/*.golden.tfvars

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Go coverage profiles (generated by `go test -coverprofile`, `task coverage`, CI)
coverage.out

# Runner-type binaries produced by `go build ./cmd/tf` / `go build ./cmd/bbrunner` at the repo root
/tf
/bbrunner
